# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings (Prisma & PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/afya_flow_db?schema=public"

# JWT Settings
JWT_SECRET="super-secret-afya-flow-key-change-this-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# CORS Configurations (Comma separated)
CORS_ORIGIN="http://localhost:5173"

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID="afya-flow-firebase-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@afya-flow-firebase-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Cloud Storage (AWS S3 or equivalent)
STORAGE_BUCKET_NAME="afya-flow-healthcare-storage"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID="your_access_key"
STORAGE_SECRET_ACCESS_KEY="your_secret_key"
