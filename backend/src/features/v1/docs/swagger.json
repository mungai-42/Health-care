{
  "openapi": "3.0.0",
  "info": {
    "title": "Afya Flow Healthcare REST API",
    "description": "Secure, production-ready healthcare REST API documentation for the Afya Flow clinic dashboard and mobile client.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Local production server Gateway"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Self-register patient or request doctor authorization credentials",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "firstName", "lastName"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 6 },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created. Verification code dispatched." }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Authenticate credentials, obtain HTTP credentials, or obtain JWT payload",
        "responses": {
          "200": { "description": "Authentication validated. Bearer token provided." }
        }
      }
    },
    "/ai": {
      "post": {
        "summary": "Query Educational healthcare AI assistant",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Secure safety reply returned with disclaimer." }
        }
      }
    },
    "/billing/invoices": {
      "get": {
        "summary": "Expose invoices history log lists",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Ledger entries returned." }
        }
      }
    }
  }
}
